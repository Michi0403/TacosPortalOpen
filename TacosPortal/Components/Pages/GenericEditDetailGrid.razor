@inject IWebAPI WebApi

@using System.Reflection
@using System.ComponentModel.DataAnnotations
@using DevExpress.Blazor
@inject INotificationService Notifier
<ToastWrapper Name="GenericEditDetailGridToasts" />
@if(TypeToDisplay!=null)
{
    @* <h3>Sub Business Objects of: @typeof(TItem)</h3> *@
    <DxGrid @ref="Grid"
    Data="@Items"
    KeyFieldNames="@KeyFieldNames"
    ValidationEnabled="true"
    EditMode="GridEditMode.EditCell"
    PageSize="30"
    ColumnResizeMode="GridColumnResizeMode.NextColumn"
    TextWrapEnabled="false"
    HighlightRowOnHover="true"
    AllowColumnReorder="true"
    AllowDragRows="true"
    AllowedDropTarget="GridAllowedDropTarget.Internal"
    AllowGroup="true"
    AllowSort="true">

        <Columns>
            @foreach (var prop in propertyInfos)
            {
                // Skip complex types
                if (prop.PropertyType.IsClass && prop.PropertyType != typeof(string))
                    continue;
                <DxGridDataColumn FieldName="@prop.Name"
                Caption="@GetDisplayName(prop)"
                DataRowEditorVisible=true />
            }

            <DxGridCommandColumn Width="120px" />
        </Columns>
    </DxGrid>
    @ChildContent
}
@code {
    IGrid? Grid { get; set; }
    [Parameter]
    public IEnumerable<object> Items { get; set; } = Array.Empty<IEnumerable<object>>();
    private PropertyInfo[] propertyInfos { get; set; } = Array.Empty<PropertyInfo>();
    private string[]? KeyFieldNames { get; set; }
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
    [Parameter] public Type? TypeToDisplay { get; set; }
