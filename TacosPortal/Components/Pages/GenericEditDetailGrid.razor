    private string GetDisplayName(PropertyInfo prop)
    {
        try
        {
            var displayAttr = prop.GetCustomAttribute<DisplayAttribute>();
            return displayAttr?.Name ?? prop.Name;
        }
        catch (Exception ex)
        {
            Notifier.ShowError("GenericEditDetailGridToasts", $"Exception: {ex.ToString()}", "Error in Grid_EditModelSaving!");
            return string.Empty;
        }
      
