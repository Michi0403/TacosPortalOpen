    private string[] GetKeyFieldNames(Type typeToGetKeyFieldNamesFrom)
    {
        try
        {
            var keyProps = typeToGetKeyFieldNamesFrom.GetProperties()
                .Where(p => p.GetCustomAttribute<KeyAttribute>() != null ||
                            p.Name.Equals("Id", StringComparison.OrdinalIgnoreCase))
                .Select(p => p.Name)
                .ToArray();

            return keyProps;
        }
        catch (Exception ex)
        {
            Notifier.ShowError("GenericEditDetailGridToasts", $"Exception: {ex}", "Error in GetKeyFieldNames!");
            return Array.Empty<string>();
        }
    } 
