@page "/servercounter"
@namespace TacosPortal.Components.Pages
@inject INotificationService Notifier
@rendermode @(new InteractiveServerRenderMode(prerender: false))
<PageTitle>Server Interactive Counter</PageTitle>

<h1>Counter ServerInteractive</h1>
<ToastWrapper Name="CounterDisplayToasts" />
<div class="counter-block">
    <div class="counter-content">
        <div class="counter-count">
            @currentCount
        </div>
        <div class="counter-text">
            current count
        </div>
        <div class="counter-block-back"></div>
    </div>
    <DxButton Click="IncrementCount">Click me</DxButton>
</div>

@code {
    private int currentCount = 0;
    private void IncrementCount()
    {
        try
        {

            currentCount++;
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Notifier.ShowError("CounterDisplayToasts", $"{ex.ToString()}", "Error in counter");
        }
    }
}
