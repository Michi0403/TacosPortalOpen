@typeparam TItem
@attribute [CascadingTypeParameter(nameof(TItem))]
@inject IWebAPI WebApi
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@using DevExpress.Blazor
@inject INotificationService Notifier
<ToastWrapper Name="GenericEditGridToasts" />
<h3>BusinessObjects: @typeof(TItem)</h3>
<DxGrid @ref="Grid"
        Data="@Items"
        KeyFieldNames="@KeyFieldNames"
        ValidationEnabled="true"
        EditMode="GridEditMode.EditCell"
        EditModelSaving="Grid_EditModelSaving"
        DataItemDeleting="Grid_DataItemDeleting"
        AutoCollapseDetailRow="true"
        PageSize="30"
        ColumnResizeMode="GridColumnResizeMode.NextColumn"
        TextWrapEnabled="false"
        HighlightRowOnHover="true"
        AllowColumnReorder="true"
        AllowDragRows="true"
        AllowedDropTarget="GridAllowedDropTarget.Internal"
        AllowGroup="true"
        AllowSort="true">

        <Columns>
        <DxGridCommandColumn />
        @foreach (var prop in propertyInfos)
        {
            // Skip complex types
            if (typeof(System.Collections.IEnumerable).IsAssignableFrom(prop.PropertyType))
            {
            @*     <DxGridDataColumn FieldName="@prop.Name"  DataRowEditorVisible=true  Caption="@GetDisplayName(prop)">
                    <EditSettings>
                        <DxComboBoxSettings Data="collectionInfoDictionary[prop.Name] "

                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                    </EditSettings>
                </DxGridDataColumn> *@
            }
            else
            {
                      <DxGridDataColumn FieldName="@prop.Name"
                      
                Caption="@GetDisplayName(prop)"
                DataRowEditorVisible=true />
            }

        }
    </Columns>
</DxGrid>
@if(Items!=null && Items.Count()>0)
{

    <GenericDataEditor Item="@Items.First()" TItem="TItem" />
}
