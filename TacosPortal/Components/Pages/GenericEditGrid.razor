    private string[] GetKeyFieldNames<T>()
    {
        try
        {
            var keyProps = typeof(T).GetProperties()
                .Where(p => p.GetCustomAttribute<KeyAttribute>() != null ||
                            p.Name.Equals("Id", StringComparison.OrdinalIgnoreCase))
                .Select(p => p.Name)
                .ToArray();

            return keyProps;
        }
        catch (Exception ex)
        {
            Notifier.ShowError("GenericEditGridToasts", $"Exception: {ex}", "Error in GetKeyFieldNames!");
            return Array.Empty<string>();
        }
    } 

    private string[] GetKeyFieldNames(Type typeToGetKeyFieldsFrom)
    {
        try
        {
            var keyProps = typeToGetKeyFieldsFrom.GetProperties()
                .Where(p => p.GetCustomAttribute<KeyAttribute>() != null ||
                            p.Name.Equals("Id", StringComparison.OrdinalIgnoreCase))
                .Select(p => p.Name)
                .ToArray();

            return keyProps;
        }
        catch (Exception ex)
        {
            Notifier.ShowError("GenericEditGridToasts", $"Exception: {ex}", "Error in GetKeyFieldNames!");
            return Array.Empty<string>();
        }
    }

    private async Task Refresh()
    {
        try
        {
            Items = await WebApi.GetAllAsync<TItem>().ConfigureAwait(false) ?? [];
            
        }
        catch (Exception ex)
        {
            Notifier.ShowError("GenericEditGridToasts", $"Exception: {ex.ToString()}", "Error in Grid_EditModelSaving!");
        }

    }

    private string GetDisplayName(PropertyInfo prop)
    {
        try
        {
            var displayAttr = prop.GetCustomAttribute<DisplayAttribute>();
            return displayAttr?.Name ?? prop.Name;
        }
        catch (Exception ex)
        {
            Notifier.ShowError("GenericEditGridToasts", $"Exception: {ex.ToString()}", "Error in Grid_EditModelSaving!");
            return string.Empty;
        }
      
    }
