            if (firstRender)
            {
                try
                {
                    PanelVisible = true;
                    await InvokeAsync(StateHasChanged).ConfigureAwait(false);
                    await LoadAsync().ConfigureAwait(true);
                  
                    await InvokeAsync(StateHasChanged).ConfigureAwait(false);
                }
                catch (JSDisconnectedException)
                {
                }
                catch (OperationCanceledException)
                { /* ignored – user navigated */
                }
                catch (Exception ex)
                {
                    Log.LogError(ex, "OnAfterRenderAsync failed");
                    Notifier.ShowError("TelegramBotCommandsToast", ex.Message, "OnAfterRenderAsync error");
                }
            }
        }
        finally
        {
            PanelVisible = false;
            // await JS.InvokeVoidAsync("scrollChatToBottom", "chat-window").ConfigureAwait(false);
            //  await InvokeAsync(StateHasChanged).ConfigureAwait(false);
