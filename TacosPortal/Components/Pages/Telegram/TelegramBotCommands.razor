@using global::Telegram.Bot
@inject ConfigurationRoot AppConfig
@implements IDisposable
@implements IAsyncDisposable
@rendermode InteractiveServer
@page "/telegramBotCommands"
<div>


    <AuthorizeView Roles="Administrators,TelegramAdmin">
            <Authorized>
                <DxLoadingPanel CssClass="w-100" @bind-Visible="PanelVisible" CloseOnClick="true"
                                IndicatorVisible="true"
                                IsContentBlocked="false"
                                IndicatorAreaVisible="false"
                                Text="Fetching Data...">

                    <ToastWrapper Name="TelegramBotCommandsToast" ThemeMode="@ToastThemeMode.Dark" />
                    <PageTitle>Telegram Bot Commands</PageTitle>
                    <h5>Telegram Rooms Known</h5>
                        <DxGrid @ref="Grid" Data="Chats" AutoCollapseDetailRow="AutoCollapseDetailRow"
                            ColumnResizeMode="GridColumnResizeMode.NextColumn" TextWrapEnabled="false" PageSize="15">
                                <Columns>
                                    <DxGridDataColumn FieldName="ID" SortIndex="0" />
                                    <DxGridDataColumn FieldName="Chat.ChatId" />
                                    <DxGridDataColumn FieldName="Chat.Type" />
                                    <DxGridDataColumn FieldName="Chat.Title" />
                                    <DxGridDataColumn FieldName="Chat.Username" />
                                    <DxGridDataColumn FieldName="Chat.FirstName" />
                                    <DxGridDataColumn FieldName="Chat.LastName" />
                                    <DxGridDataColumn FieldName="Chat.IsForum" />
                                    <DxGridDataColumn FieldName="Chat.IsForum" />
                                    <DxGridDataColumn FieldName="DateCreated" />
                                 </Columns>
                        <DetailRowTemplate Context="rowContext">
                            <ChatDetail ChatFullInfo="(TelegramChatFullInfo)rowContext.DataItem" />
                                </DetailRowTemplate>
                        <ToolbarTemplate Context="toolbarContext">
                                    <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
                                        <Items>
                                            <DxToolbarItem BeginGroup="true" Alignment="ToolbarItemAlignment.Left">
                                                <Template Context="toolbar_item_context">
                                                    <div class="d-flex flex-row align-items-center">
                                                        <DxCheckBox @bind-Checked="AutoCollapseDetailRow">
                                                            Auto Collapse Detail Rows
                                                        </DxCheckBox>
                                                    </div>
                                                </Template>
                                            </DxToolbarItem>
                                        </Items>
                                    </DxToolbar>
                                </ToolbarTemplate>
                         </DxGrid>
                </DxLoadingPanel>

            </Authorized>
            <NotAuthorized>
            <LoginDisplay />
            </NotAuthorized>
        </AuthorizeView>
</div>
