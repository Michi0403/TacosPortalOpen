    async Task LoadAsync()
    {
        try
        {
            PanelVisible = true;
            using (var ctsUser = new CancellationTokenSource(TimeSpan.FromSeconds(120)))
            {
                var data = await WebApi.GetAllAsync<TelegramChatFullInfo>(ctsUser.Token, additionalQuery: "$expand=Chat&$filter=Chat/ChatToIgnore eq false or Chat/ChatToIgnore eq null").ConfigureAwait(false);
                if (data != null)
                {
                    await InvokeAsync(async () =>
                    {
                        await Chats.SyncWith(
                        data, m => m.Chat.ChatId, configuredTaskAwaitableToInformUpdates: InvokeAsync(StateHasChanged).ConfigureAwait(false)).ConfigureAwait(false);
                    }).ConfigureAwait(false);
                }

                await base.OnInitializedAsync().ConfigureAwait(false);
            }
          
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (HttpRequestException ex)
        {
            Log.LogError(ex, $"Error in LoadAsync HTTPRequestexception: {ex.ToString()}");
            if (ex.StatusCode != System.Net.HttpStatusCode.Unauthorized)
            {
                throw;
            }
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"GetMyUserAsync failed {ex.ToString()}");
            Notifier.ShowError("TelegramBotCommandsToast", ex.Message, "LoadAsync error");
        }
        finally
        {
            PanelVisible = false;
        }
    }

