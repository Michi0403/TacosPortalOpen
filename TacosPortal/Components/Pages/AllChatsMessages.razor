    async Task LoadAsync()
    {
        try
        {
            PanelVisible = true;

            using (var cts = new CancellationTokenSource(TimeSpan.FromSeconds(120)))
            {
                var mentionData = await WebApi.GetAllAsync<TelegramUser>(cts.Token).ConfigureAwait(false);
                if (mentionData != null)
                {
                    await InvokeAsync(async () =>
                    {
                        await TelegramUsersData.SyncWith(mentionData, User => User.UserId, configuredTaskAwaitableToInformUpdates: InvokeAsync(StateHasChanged).ConfigureAwait(false)).ConfigureAwait(false);
                    }).ConfigureAwait(false);
                }
            }
            using (var cts2 = new CancellationTokenSource(TimeSpan.FromSeconds(120)))
            {
                var messagesData = await WebApi.GetAllAsync<TelegramMessage>(additionalQuery: $"$expand=Chat,From&$select=Message_ID,Chat,From,Text,Date&$orderby=Date asc").ConfigureAwait(false);

                if (messagesData != null)
                {
                    await InvokeAsync(async () =>
                    {
                        await TelegramMessages.SyncWith(
                        messagesData.Where(m => m.Message_ID.HasValue), m => m.Message_ID!.Value, configuredTaskAwaitableToInformUpdates: InvokeAsync(StateHasChanged).ConfigureAwait(false)).ConfigureAwait(false);
                    }).ConfigureAwait(false);
                }
                if(messagesData!=null && messagesData.Count()>0)
                {
                    var missingId = messagesData.Where(m => !m.Message_ID.HasValue).ToList();
                    if (missingId.Any())
                        Log.LogWarning($"Messages with missing ID: {missingId.Count}");
                }
            }

            await UpdateChatFullInfos().ConfigureAwait(false);
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (HttpRequestException ex)
        {
            Log.LogError(ex, $"Error in LoadAsync HTTPRequestexception: {ex.ToString()}");
            if (ex.StatusCode != System.Net.HttpStatusCode.Unauthorized)
            {
                throw;
            }
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"GetMyUserAsync failed {ex.ToString()}");
            Notifier.ShowError("SendMessageGlobalToasts", ex.Message, "LoadAsync error");
        }
        finally
        {
            PanelVisible = false;
        }
    }

