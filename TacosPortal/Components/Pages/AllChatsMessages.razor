    protected virtual void Dispose(bool disposing)
    {
        try
        {
            if (_disposed)
                return;

            if (disposing)
            {
                // _ctsTimerTask?.Cancel();
                // _ctsTimerTask?.Dispose();
                markup = string.Empty;
                if (!TelegramUsersData.Any())
                    TelegramUsersData.Clear(); // safe
                else
                    TelegramUsersData = new(); // safer, breaks bindings
                if (!TelegramMessages.Any())
                    TelegramMessages.Clear(); // safe
                else
                    TelegramMessages = new(); // safer, breaks bindings
                tacosApi?.Dispose();
                WebApi?.Dispose();
                Log.LogInformation("Executing Dispose");
                _disposed = true;
            }

            _disposed = true;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in Dispose {ex.ToString()}");
        }

    }
    public async ValueTask DisposeAsync()
    {
        if (_disposed)
            return;

        _disposed = true;

        try
        {
            if (_hubConnection != null)
            {
                if (_hubConnection.State != HubConnectionState.Disconnected)
                    await _hubConnection.StopAsync().ConfigureAwait(false);

                await _hubConnection.DisposeAsync().ConfigureAwait(false);
                _hubConnection = null;
            }
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Error in DisposeAsync");
        }

        Dispose(disposing: false);
        GC.SuppressFinalize(this);
    }
