            fontElementGroup.Items.Remove(HtmlEditorToolbarItemNames.FontColor);
            fontElementGroup.Items.Remove(HtmlEditorToolbarItemNames.BulletList);
            fontElementGroup.Items.Remove(HtmlEditorToolbarItemNames.FontSize);
            fontElementGroup.Items.Remove(HtmlEditorToolbarItemNames.FontName);
            fontElementGroup.Items.Remove(HtmlEditorToolbarItemNames.NumberedList);
            fontElementGroup.Items.Remove(HtmlEditorToolbarItemNames.FontSubscript);
            fontElementGroup.Items.Remove(HtmlEditorToolbarItemNames.FontSuperscript);
            sortElementGroup.Items.Clear();
            tableElementGroup.Items.Clear();
            // Removes all items
            // insertElementGroup.Items.Clear();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in OnCustomieToolbar {ex.ToString()}");
        }
    }
}
