<div>
    <h5>Send Message Global ServerInteractive</h5>

    <AuthorizeView Roles="Administrators,TelegramAdmin">
            <Authorized >
                <DxLoadingPanel CssClass="w-100" @bind-Visible="PanelVisible" CloseOnClick="true"
                                IndicatorVisible="true"
                                IsContentBlocked="false"
                                IndicatorAreaVisible="false"
                                Text="Fetching Data...">

                    <ToastWrapper Name="SendMessageGlobalToasts" ThemeMode="@ToastThemeMode.Dark" />
                    <PageTitle>Administration ServerInteractive</PageTitle>
                    <div >
                        <DxCheckBox @bind-Checked="@AutoScollEnable">AutoScroll Enable</DxCheckBox>
                    </div>
                    @if (_hubConnection != null)
                    {
                        @switch(_hubConnection.State)
                        {
                            @case HubConnectionState.Connecting:
                            @case HubConnectionState.Reconnecting:
                                <h5 class="text-warning">Connection State: @_hubConnection.State.ToString()</h5>
                                break;
                            @case HubConnectionState.Connected:
                                <h5 class="text-success">Connection State: @_hubConnection.State.ToString()</h5>
                                break;
                            @case HubConnectionState.Disconnected:
                                <h5 class="text-danger">Connection State: @_hubConnection.State.ToString()</h5>
                                break;
                        }
                        
                    }
                    else
                    {
                    <h5 class="text-danger">Signal R Hub connection still builds up, takes some seconds... no haste...</h5>
                    }
                        <div id="chat-container">
                    <div id="chat-window">
 
                        @foreach (var message in TelegramMessages)
                        {
                            <div class="message" tabindex="0">
                                <div class="name">
                                    Chat: @message.Chat?.Title
                                    DateTime: @(message.Date == default || message.Date == null ? "N/A" : message.Date.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss"))
                                    UserID: @message.From?.UserId |
                                    Username: @message.From?.Username |
                                    Firstname: @message.From?.FirstName |
                                    Lastname: @message.From?.LastName |
                                    Language: @message.From?.LanguageCode
                                    IsBot: @message.From?.IsBot
                                    @if(message.ReplyToMessage!=null)
                                    {
                                        <p>
                                            Reply To @(message.ReplyToMessage?.Date == default || message.ReplyToMessage?.Date == null ? "N/A" : message.ReplyToMessage?.Date.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss"))
                                            @message.ReplyToMessage?.From?.Username
                                            @message.ReplyToMessage?.Text</p>
                                       
                                    }
                                </div>
                                <div class="text">@message.Text</div>
                            </div>
                        }
                    </div>

                </div>
                <div id="editor-container">
                    <div id="editor-container-row" class="editor-button-row">
                        <DxHtmlEditor @ref="@htmlEditor"
                                      Height="200px"
                                      @bind-Markup="@markup"
                                      CustomizeToolbar="@OnCustomizeToolbar"
                                      BindMarkupMode="HtmlEditorBindMarkupMode.OnDelayedInput"
                                      InputDelay="100"
                                      IsValid="@isValid"
                                      MediaResizeEnabled="true"
                                      TableResizeEnabled="true"
                                      AllowSoftLineBreak="true"
                                      CssClass="editor-area">
                            <DxHtmlEditorMentions>
                                <DxHtmlEditorMention Data="@TelegramUsersData"
                                                     DisplayFieldName="@nameof(TelegramUser.Username)"
                                                     SearchFieldNames="@SearchFieldNames" />
                            </DxHtmlEditorMentions>
                        </DxHtmlEditor>

                        <DxButton Text="Send"
                                  SizeMode="SizeMode.Large"
                                  Click="OnClick"
                                  CssClass="chat-button" />
                    </div>
                </div>
                </DxLoadingPanel>

            </Authorized>
            <NotAuthorized>
                <LoginDisplay />
            </NotAuthorized>
        </AuthorizeView>
</div>
