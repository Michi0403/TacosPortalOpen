    private Uri GetSafeHubUri()
    {
        if (_hubUri != null) return _hubUri;

        if (NavManager.Uri.StartsWith("http"))
        {
            _hubUri = UriBuilderHelper.BuildAbsoluteUriFromConfig("chathub");
        }
        else
        {
            // still prerendering, postpone init
            throw new InvalidOperationException("Attempted to build hub URI during prerender.");
        }

        return _hubUri;
    }

