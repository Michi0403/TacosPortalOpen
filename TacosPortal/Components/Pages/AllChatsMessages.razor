    private async Task SetupSignalR()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(GetSafeHubUri())
            .AddJsonProtocol(configure=>
            {
                configure.PayloadSerializerOptions = new()
                {
                    ReferenceHandler = ReferenceHandler.Preserve,
                    PropertyNameCaseInsensitive = true,
                    WriteIndented = true,
                    PropertyNamingPolicy = null,
                    IgnoreReadOnlyFields = false,
                    IgnoreReadOnlyProperties = false,
                    IncludeFields = false,
                    DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
                    AllowTrailingCommas = true,
                    NumberHandling = JsonNumberHandling.AllowReadingFromString | JsonNumberHandling.WriteAsString


                };
            })
            //.AddMessagePackProtocol()
            .WithAutomaticReconnect()
            .Build(); //   ./* AddMessagePackProtocol ()*/
        _hubConnection.KeepAliveInterval = TimeSpan.FromSeconds(120);
        _hubConnection.ConfigureAwait(false);
        _hubConnection.HandshakeTimeout = TimeSpan.FromSeconds(30);
        _hubConnection.Reconnecting += async (error) =>
        {

            try
            {
                Log.LogWarning("SignalR disconnected, attempting to reconnect...");
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                Log.LogError(ex, $"Reconnecting failed {ex.ToString()}");
            }
        };
        _hubConnection.Reconnected += async (error) =>
          {

              try
              {
                  Log.LogWarning("SignalR reconnected");
                  await InvokeAsync(StateHasChanged).ConfigureAwait(false);
              }
              catch (Exception ex)
              {
                  Log.LogError(ex, $"Reconnected failed {ex.ToString()}");
              }
          };

        // _hubConnection.Closed += async (error) =>
        // {
        //     Log.LogWarning("SignalR closed, attempting to reconnect...");
        //     await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        //     await Task.Delay(Random.Shared.Next(0, 5) * 1000).ConfigureAwait(false); // jitter delay
        //     try
        //     {
        //         if (_hubConnection.State == HubConnectionState.Disconnected)
        //             await _hubConnection.StartAsync().ConfigureAwait(false);
        //     }
        //     catch (Exception ex)
        //     {
        //         Log.LogError(ex, "Reconnect failed");
        //     }
        // };
        _hubConnection.Closed += async (error) =>
        {
            Log.LogWarning("SignalR closed, attempting to reconnect...");
            // Prevent reconnection if the hub has already been disposed
            if (_disposed)
            {
                Log.LogInformation("HubConnection was disposed. Skipping reconnect.");
                return;
            }
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            await Task.Delay(Random.Shared.Next(0, 5) * 1000).ConfigureAwait(false); // jitter delay

            try
            {
                if (_hubConnection.State == HubConnectionState.Disconnected)
                    await _hubConnection.StartAsync().ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                Log.LogError(ex, $"Reconnect failed {ex.ToString()}");
            }
        };

        _hubConnection.On<TelegramMessage>("ReceiveTelegramMessage", async (message) =>
        {
            try
            {
                await InvokeAsync(() =>
                  {
                      if (!TelegramMessages.Any(m => m.Message_ID == message.Message_ID))
                      {
                          TelegramMessages.Add(message);
                      }

                  }).ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
                if (AutoScollEnable)
                {
                    await ScrollToButtom().ConfigureAwait(false);
                }
            }
            catch (Exception ex)
            {
                Log.LogError(ex, $"ReceiveTelegramMessage async failed for{ex.ToString()} {message.ToString()}.");
            }
        });

        try
        {
            if (_hubConnection.State == HubConnectionState.Disconnected)
            {
                await _hubConnection.StartAsync().ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
            Log.LogInformation("Connected to SignalR ChatHub");
        }
        catch(TaskCanceledException ex)
        {
            //Ignore
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"SignalR connection failed. {ex.ToString()}");
        }
    }
