    private async Task OnClick()
    {
        try
        {
            await UpdateChatFullInfos().ConfigureAwait(false);

            string sanitizedMarkup = markup.Replace("<p>", "").Replace("</p>", "").Replace("<br>", "").Replace("<br />", "");
            List<string> chatResults = new();
            foreach (var chat in TelegramChatFullInfos)
            {
                try
                {
                    await Task.Delay(25).ConfigureAwait(false);
                    using(var cts = new CancellationTokenSource(10000))
                    {
                        await telegramBot.SendMessage(chat.Id, sanitizedMarkup, ParseMode.Html,cancellationToken: cts.Token).ConfigureAwait(false);
                        chatResults.Add($"Send Message To: {chat.ToString()}");
                    }

                }
                catch (Exception ex)
                {
                    Log.LogWarning(ex, $"Error in Onclick while sending message {ex.ToString()}");
                }

            }
            StringBuilder stringBuilder = new();
            foreach (var stringi in chatResults)
                stringBuilder.AppendLine(stringi);

            ArgumentNullException.ThrowIfNullOrWhiteSpace(stringBuilder.ToString());
            Notifier.ShowRegular("SendMessageGlobalToasts", stringBuilder.ToString(), "Result of Send Message Action");
            PanelVisible = true;
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in OnInitializedAsync {ex.ToString()}");
            Notifier.ShowError("SendMessageGlobalToasts", $"Exception: {ex.ToString()}", "Error in OnInitializedAsync!");
        }
        finally
        {
            PanelVisible = false;
        }
    }

