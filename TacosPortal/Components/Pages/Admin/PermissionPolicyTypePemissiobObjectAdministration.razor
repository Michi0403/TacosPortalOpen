@using TacosCore.BusinessObjects.DataTypes.PermissionBaseObjects
@inject IWebAPI WebApi
@inject INotificationService Notifier
@inject ILogger<PermissionPolicyTypePemissiobObjectAdministration> Log
@rendermode InteractiveServer
<div>
    <AuthorizeView Roles="Administrators,TelegramAdmin">
        <Authorized>

        </Authorized>
        <NotAuthorized>
            <p>Not Authorized or not logged in</p>
            <LoginDisplay />
        </NotAuthorized>
    </AuthorizeView>
    <DxLoadingPanel   CssClass="w-100" @bind-Visible="PanelVisible"  CloseOnClick="true"   IndicatorVisible="true"
                IsContentBlocked="false"
                IndicatorAreaVisible="false"
                Text="Fetching Data...">

        <h5>PermissionPolicyTypePermissionObject Administration</h5>
        <ToastWrapper Name="PermissionPolicyTypePermissionObjectAdministrationToasts" />

        <DxGrid @ref="Grid"
        AllowSelectRowByClick="true"
        Data="DataSource"
        KeyFieldName="ID"
        ValidationEnabled="false"
        EditMode="@CurrentEditMode"
        EditStart="OnGridEditStart"
                AllowColumnReorder="true"
                AllowDragRows="true"
                AllowGroup="true"
                AllowSort="true"
                ShowGroupPanel="true"
                ShowFilterRow="true"
                ShowSearchBox="true"
                SearchBoxNullText="Search for whatever... Fulltext"
        ColumnResizeMode="GridColumnResizeMode.NextColumn"
        TextWrapEnabled="false"
        ShowAllRows="true"
        HighlightRowOnHover="true" EditorRenderMode="GridEditorRenderMode.Integrated"
        SelectionMode="@GridSelectionMode.Single"
        EditModelSaving="OnGridModelSavingAsync"
        DataItemDeleting="OnGridModelDeleteAsync"
        CustomizeEditModel="Grid_CustomizeEditModel"
        >

            <Columns>
                <DxGridCommandColumn  />
                <DxGridDataColumn FieldName="ID" />
                <DxGridDataColumn FieldName="TargetTypeFullName" />
                <DxGridDataColumn FieldName="ReadState" />
                <DxGridDataColumn FieldName="WriteState" />
                <DxGridDataColumn FieldName="CreateState" />
                <DxGridDataColumn FieldName="DeleteState" />
                <DxGridDataColumn FieldName="NavigateState" />
                <DxGridDataColumn FieldName="Role.Name" />
            </Columns>
            <EditFormTemplate Context="EditFormContext">
                @{
                    var user = (PermissionPolicyTypePermissionObject)EditFormContext.EditModel;
                }
                <DxFormLayout SizeMode="SizeMode.Large">

                    <DxFormLayoutItem Caption="ID:" ColSpanMd="12">
                        @EditFormContext.GetEditor(nameof(PermissionPolicyTypePermissionObject.ID))
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="TargetTypeFullName:" ColSpanMd="12">
                        @EditFormContext.GetEditor(nameof(PermissionPolicyTypePermissionObject.TargetTypeFullName))
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="ReadState:" ColSpanMd="12">
                        @EditFormContext.GetEditor(nameof(PermissionPolicyTypePermissionObject.ReadState))
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="WriteState:" ColSpanMd="12">
                        @EditFormContext.GetEditor(nameof(PermissionPolicyTypePermissionObject.WriteState))
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="CreateState:" ColSpanMd="12" Visible="@IsNew" Enabled="false">
                        @EditFormContext.GetEditor(nameof(PermissionPolicyTypePermissionObject.CreateState))
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="DeleteState:" ColSpanMd="12" Visible="@IsNew" Enabled="false">
                        @EditFormContext.GetEditor(nameof(PermissionPolicyTypePermissionObject.DeleteState))
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="NavigateState:" ColSpanMd="12">
                        @EditFormContext.GetEditor(nameof(PermissionPolicyTypePermissionObject.NavigateState))
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Role:" ColSpanMd="12" Visible="@IsNew" Enabled="@IsNew">
                        <DxListBox 
                        SelectionMode="ListBoxSelectionMode.Single"
                        @bind-SearchText="@SearchListboxText"
                        ShowCheckboxes="@true"
                        ShowSearchBox="true"
                        SearchTextParseMode="@SearchTextParseMode"
                        Data="@AvailableRoles"
                        TextFieldName="Name"
                        ValueFieldName="ID"
                        @bind-Value="@CurrentPermissionPolicyRole">
                        </DxListBox>
                    </DxFormLayoutItem>
                </DxFormLayout>
            </EditFormTemplate>

            <ToolbarTemplate>
                <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
                    <Items>
                        <DxToolbarItem BeginGroup="true" Alignment="ToolbarItemAlignment.Left">
                            <Template Context="toolbar_item_context">
                                <div class="d-flex flex-row align-items-center h-100">
                                    <DxCheckBox Checked="UsePopupEditForm" CheckedChanged="new Func<bool, Task>(UsePopupEditForm_CheckedChanged)">Use Popup Edit Form</DxCheckBox>
                                </div>
                            </Template>
                        </DxToolbarItem>
                    </Items>
                </DxToolbar>
            </ToolbarTemplate>
        </DxGrid>
    </DxLoadingPanel>
</div>
@code {
    List<PermissionPolicyTypePermissionObject> DataSource { get; set; } = new();
    List<TacoPermissionPolicyRole> AvailableRoles { get; set; } = new();
    TacoPermissionPolicyRole CurrentPermissionPolicyRole { get; set; } = new();
    PermissionPolicyTypePermissionObject CurrentPermissionPolicyMemberPermissionsObject { get; set; } = new();
    bool IsNew { get; set; } = true;
    string SelectionChangesInfo { get; set; } = string.Empty;
    bool PanelVisible { get; set; } = true;
    IGrid? Grid { get; set; }
    bool UsePopupEditForm { get; set; } = false;
    string SearchListboxText { get; set; } = string.Empty;
    ListSearchTextParseMode SearchTextParseMode { get; set; } = ListSearchTextParseMode.GroupWordsByAnd;
    GridEditMode CurrentEditMode { get { return UsePopupEditForm ? GridEditMode.PopupEditForm : GridEditMode.EditForm; } }
    async Task UsePopupEditForm_CheckedChanged(bool value)
    {
        try
        {
            UsePopupEditForm = value;
            ArgumentNullException.ThrowIfNull(Grid);
            await Grid.CancelEditAsync().ConfigureAwait(false);
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in UsePopupEditForm_CheckedChanged {ex.ToString()}");
            Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Exception: {ex.ToString()}", "Error in UsePopupEditForm_CheckedChanged!");
        }

    }
    void Grid_CustomizeEditModel(GridCustomizeEditModelEventArgs e)
    {
        try
        {
            if (e.IsNew)
            {
                IsNew = false;
                var newy = (PermissionPolicyTypePermissionObject)e.EditModel;
                newy.ID = Guid.NewGuid();
                if (AvailableRoles != null && AvailableRoles.Count() > 0)
                {
                    var defaultRole = AvailableRoles.FirstOrDefault(x => x.IsAdministrative == false && x.Name.ToLowerInvariant().Contains("default"));
                    if (defaultRole != null)
                    {
                        newy.Role = defaultRole;
                    }
                    else
                        newy.Role = AvailableRoles.FirstOrDefault(x => x.IsAdministrative == false);
                }
            }
            else
                IsNew = true;
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in Grid_CustomizeEditModel {ex.ToString()}");
            Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Exception: {ex.ToString()}", "Error in Grid_CustomizeEditModel!");
        }

    }
    void OnGridEditStart(GridEditStartEventArgs e)
    {
        try
        {
            if(e.IsNew)
            {
                IsNew = false;
                var newy = new PermissionPolicyTypePermissionObject();
                newy.ID = Guid.NewGuid();
                if (AvailableRoles != null && AvailableRoles.Count() > 0)
                {
                    var defaultRole = AvailableRoles.FirstOrDefault(x => x.IsAdministrative == false && x.Name.ToLowerInvariant().Contains("default"));
                    if (defaultRole != null)
                    {
                        newy.Role = defaultRole;
                    }
                    else
                        newy.Role = AvailableRoles.FirstOrDefault(x => x.IsAdministrative == false);
                }
                CurrentPermissionPolicyMemberPermissionsObject = newy;
            }
            else
            {
                IsNew = true;
                if(e.DataItem is PermissionPolicyTypePermissionObject tmpPermissionPolicyTypePermissionObject)
                    CurrentPermissionPolicyMemberPermissionsObject = tmpPermissionPolicyTypePermissionObject;
            }
            if (CurrentPermissionPolicyMemberPermissionsObject != null && CurrentPermissionPolicyMemberPermissionsObject.Role != null && CurrentPermissionPolicyMemberPermissionsObject.Role is TacoPermissionPolicyRole tmpPermissionPolicyRole)
                CurrentPermissionPolicyRole = tmpPermissionPolicyRole;
            else
                CurrentPermissionPolicyRole = new ();

        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in OnGridEditStart {ex.ToString()}");
            Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Exception: {ex.ToString()}", "Error in OnGridEditStart!");
        }
    }

    async Task OnGridModelSavingAsync(GridEditModelSavingEventArgs e)
    {
        try
        {
            PanelVisible = true;

            if (e.EditModel != null && e.EditModel is PermissionPolicyTypePermissionObject permissionPolicyTypePermissionObject)
            {
                if (e.IsNew)
                {
                    IsNew = false;
                    var updatedPermissionPolicyTypePermissionObject = new
                    {
                        ID = permissionPolicyTypePermissionObject.ID
                    };
                    var response = await WebApi.PostAsync<PermissionPolicyTypePermissionObject, object>(updatedPermissionPolicyTypePermissionObject).ConfigureAwait(false);
                    if (response != null)
                    {
                        Notifier.ShowSuccess("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Response: '{response}'!", "Success in OnGridModelSavingAsync!");

                    }
                    else
                    {
                        Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Failed to create TelegramUser: {updatedPermissionPolicyTypePermissionObject.ToJsonString()}", "Error in OnGridModelSavingAsync!");
                    }
                }
                else
                {
                    IsNew = true;
                    var updatedUser = new                    {

                        ID = permissionPolicyTypePermissionObject.ID,
                        TargetTypeFullName = permissionPolicyTypePermissionObject.TargetTypeFullName,
                        ReadState = permissionPolicyTypePermissionObject.ReadState,
                        WriteState = permissionPolicyTypePermissionObject.WriteState,
                        CreateState = permissionPolicyTypePermissionObject.CreateState,
                        DeleteState = permissionPolicyTypePermissionObject.DeleteState,
                        NavigateState = permissionPolicyTypePermissionObject.NavigateState,
                        Role = new { ID = permissionPolicyTypePermissionObject.Role.ID, Name = permissionPolicyTypePermissionObject.Role.Name }
                    };
                    // PatchPartialAsync
                    bool success = await WebApi.PatchPartialAsync<PermissionPolicyTypePermissionObject, object>(updatedUser).ConfigureAwait(false);

                    CurrentPermissionPolicyMemberPermissionsObject.Role = CurrentPermissionPolicyRole;
                    //Put new Refs
                    if (CurrentPermissionPolicyMemberPermissionsObject.Role != null)
                    {
                        success = await WebApi.PutRefAsync<PermissionPolicyTypePermissionObject, TacoPermissionPolicyRole>(CurrentPermissionPolicyMemberPermissionsObject).ConfigureAwait(false);
                        if (success)
                        {

                            Notifier.ShowSuccess("PermissionPolicyTypePermissionObjectAdministrationToasts", $"TelegramUser '{updatedUser.ToJsonString()}' roles updated successfully!", "Success in OnGridModelSavingAsync!");

                        }
                        else
                        {
                            Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Failed to update user: {updatedUser.ToJsonString()}", "Error in OnGridModelSavingAsync!");
                        }
                    }
                    if (success)
                    {

                        Notifier.ShowSuccess("PermissionPolicyTypePermissionObjectAdministrationToasts", $"TelegramUser '{updatedUser.ToJsonString()}' updated successfully!", "Success in OnGridModelSavingAsync!");

                    }
                    else
                    {
                        Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Failed to update user: {updatedUser.ToJsonString()}", "Error in OnGridModelSavingAsync!");
                    }
                };
                CurrentPermissionPolicyMemberPermissionsObject = permissionPolicyTypePermissionObject;
                await OnInitializedAsync().ConfigureAwait(false);
            }

        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in OnGridModelSavingAsync {ex.ToString()}");
            Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Exception: {ex.ToString()}", "Error in OnGridModelSavingAsync!");
        }
        finally
        {
            PanelVisible = false;
        }
    }
    async Task OnGridModelDeleteAsync(GridDataItemDeletingEventArgs e)
    {
        try
        {
            PanelVisible = true;
            if(e.DataItem is PermissionPolicyTypePermissionObject tmpPermissionPolicyTypePermissionObject)
                //var deletedUser = e.DataItem as PermissionPolicyTypePermissionObject;
                try
                {
                    await WebApi.DeleteAsync<PermissionPolicyTypePermissionObject>(tmpPermissionPolicyTypePermissionObject).ConfigureAwait(false);

                    e.Reload = true;
                }
                catch (Exception ex)
                {
                    Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Exception: {ex.ToString()}", "Error in OnGridModelDeleteAsync!");
                }
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in OnGridModelDeleteAsync {ex.ToString()}");
            Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Exception: {ex.ToString()}", "Error in OnGridModelDeleteAsync!");
        }
        finally
        {
            PanelVisible = false;
        }
    }


    protected override async Task OnInitializedAsync()
    {
        try
        {
            PanelVisible = true;
            await LoadAsync().ConfigureAwait(false);
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"Error in OnInitializedAsync {ex.ToString()}");
            Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", $"Exception: {ex.ToString()}", "Error in OnInitializedAsync!");
        }
        finally
        {
            PanelVisible = false;
        }
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {

            PanelVisible = true;

            if (firstRender)
            {
                try
                {

                    await LoadAsync().ConfigureAwait(false);
                }
                catch (OperationCanceledException)
                { /* ignored – user navigated */
                }
                catch (Exception ex)
                {
                    Log.LogError(ex, $"OnAfterRenderAsync failed {ex.ToString()}");
                    Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", ex.Message, "OnAfterRenderAsync error");
                }
            }
        }
        finally
        {
            PanelVisible = false;

        }

    }

    async Task LoadAsync()
    {
        try
        {
            PanelVisible = true;

            using (var ctsUser = new CancellationTokenSource(TimeSpan.FromSeconds(120)))
            {
                var data = await WebApi.GetAllAsync<PermissionPolicyTypePermissionObject>().ConfigureAwait(false);
                DataSource = data.ToList();
                if(DataSource!=null && DataSource.Count>0)
                {
                    var tmpEntry = DataSource.FirstOrDefault();
                    if (tmpEntry != null)
                        CurrentPermissionPolicyMemberPermissionsObject = tmpEntry; 
                }
               
            
            }
            using (var ctsPermissionPolcyRole = new CancellationTokenSource(TimeSpan.FromSeconds(120)))
            {
                var roles = await WebApi.GetAllAsync<TacoPermissionPolicyRole>().ConfigureAwait(false);
                AvailableRoles = roles.ToList();
     
                
            }
            if (CurrentPermissionPolicyMemberPermissionsObject != null && CurrentPermissionPolicyMemberPermissionsObject.Role is TacoPermissionPolicyRole role)
                CurrentPermissionPolicyRole = role;
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (HttpRequestException ex)
        {
            Log.LogError(ex, $"Error in LoadAsync HTTPRequestexception: {ex.ToString()}");
            if (ex.StatusCode != System.Net.HttpStatusCode.Unauthorized)
            {
                throw;
            }
        }
        catch (Exception ex)
        {
            Log.LogError(ex, $"GetMyUserAsync failed {ex.ToString()}");
            Notifier.ShowError("PermissionPolicyTypePermissionObjectAdministrationToasts", ex.Message, "LoadAsync error");
        }
        finally
        {
            PanelVisible = false;
        }
    }
}