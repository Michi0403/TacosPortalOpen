    private bool _hasUpdated = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {

            if (firstRender && !_hasUpdated)
            {
                PanelVisible = true;
                ClientFactory.CreateWASMClient(NavigationManager, Logger, out HttpClient? client);
                if (client != null) Http = client;
                await LoadDataAsync().ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Exception in OnAfterRenderAsync: {ex.ToString()}");
            Notifier.ShowError("UserAdministrationToastsWASM", $"Exception: {ex.ToString()}", "Error in OnAfterRender!");
        }
        finally
        {
            PanelVisible = false;
        }
    }

