                    //     .ToList();
                }
            }
        
        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, $"Error in LoadAsync HTTPRequestexception: {ex.ToString()}");
            if (ex.StatusCode != System.Net.HttpStatusCode.Unauthorized)
            {
                throw;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"LoadAsync failed {ex.ToString()}");
            Notifier.ShowError("TeamAdministrationToasts", ex.Message, "LoadAsync error");
        }
        finally
