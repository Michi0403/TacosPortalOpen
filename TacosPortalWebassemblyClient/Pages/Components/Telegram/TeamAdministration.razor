    async Task OnGridModelDeleteAsync(GridDataItemDeletingEventArgs e)
    {
        try
        {
            ArgumentNullException.ThrowIfNull(Http);
            PanelVisible = true;

            if (e.DataItem is TacoTeam tmpTacoTeam)
            {
                try
                {
                    using (var cts = new CancellationTokenSource(TimeSpan.FromSeconds(60)))
                    {
                        await Http.DeleteAsync<TacoTeam>(tmpTacoTeam, Logger, cts.Token).ConfigureAwait(false);

                        e.Reload = true;
                    }

                }

                catch (Exception ex)
                {
                    Logger.LogError(ex, $"Exception in OnGridModelDeleteAsync: {ex.ToString()}");
                    Notifier.ShowError("TeamAdministrationToasts", $"Can't delete TacoTeam {tmpTacoTeam.ToString()}Exception: {ex.ToString()}", "Error in OnGridModelDeleteAsync!");
                }
            }

        }
        catch (OperationCanceledException)
        { /* ignored – user navigated */
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Error in OnGridModelDeleteAsync {ex.ToString()}");
